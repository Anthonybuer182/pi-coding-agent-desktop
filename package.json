{
  "name": "pi-coding-agent-desktop",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "keywords": [
    "ai",
    "coding-assistant",
    "electron",
    "react",
    "desktop-app",
    "ai-programming"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Anthonybuer182/pi-coding-agent-desktop.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev:web": "turbo run dev --filter=@pi/web",
    "dev:desktop": "turbo run dev --filter=@pi/desktop",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "clean": "turbo run clean",
    "pack:mac": "cd apps/desktop && pnpm pack:mac",
    "pack:win": "cd apps/desktop && pnpm pack:win",
    "pack:linux": "cd apps/desktop && pnpm pack:linux",
    "pack:all": "cd apps/desktop && pnpm pack:all"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "^0.78.1",
    "@earendil-works/pi-ai": "^0.78.1",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "^5.9.3"
  }
}
