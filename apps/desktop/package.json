{
  "name": "@pi/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "./out/main/index.mjs",
  "description": "Pi Coding Agent - Desktop Application",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf out dist",
    "start": "electron .",
    "pack:mac": "pnpm build && node scripts/prepare-pack.cjs && electron-builder --mac",
    "pack:win": "pnpm build && node scripts/prepare-pack.cjs && electron-builder --win",
    "pack:linux": "pnpm build && node scripts/prepare-pack.cjs && electron-builder --linux",
    "pack:all": "pnpm build && node scripts/prepare-pack.cjs && electron-builder --mac --win --linux"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.1",
    "@tanstack/react-query": "^5.62.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@pi/sdk-wrapper": "workspace:*",
    "@pi/types": "workspace:*",
    "@pi/ui": "workspace:*",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^38.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.0"
  }
}
